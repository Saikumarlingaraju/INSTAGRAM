# ── Server-side only (Vercel env vars) ──
# Bot token is NEVER exposed to the client — all Telegram calls
# are proxied through /api/send-telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
CRON_SECRET=your-random-secret-here

# ── Optional but recommended: Vercel KV for persistent dedup ──
# Add Vercel KV integration and these vars will be injected automatically.
KV_REST_API_URL=your-kv-rest-url
KV_REST_API_TOKEN=your-kv-rest-token
